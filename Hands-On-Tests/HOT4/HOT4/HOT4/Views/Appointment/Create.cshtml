@model Appointment

@{
    ViewData["Title"] = "Create Appointment";
}

<div class="max-w-xl mx-auto mt-10 bg-white dark:bg-gray-900 shadow-lg rounded-xl p-8">
    <h2 class="text-2xl font-semibold text-gray-800 dark:text-gray-100 mb-6">
        Create Appointment
    </h2>

    <form asp-action="Create" method="post" class="space-y-6">
        <div asp-validation-summary="All" class="text-red-500"></div>
        <!-- Start Date -->
        <div>
            <label asp-for="StartDate" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Appointment Date</label>
            <input asp-for="StartDate" type="datetime-local"
                   class="w-full px-4 py-2 rounded-lg border border-gray-300 dark:border-gray-700
            bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-gray-100
            focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition" />
            <span asp-validation-for="StartDate" class="text-red-500 text-sm"></span>
        </div>

        <div>
            <label asp-for="Summary" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Appointment Summary</label>
            <input asp-for="Summary" type="text"
                   class="w-full px-4 py-2 rounded-lg border border-gray-300 dark:border-gray-700
            bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-gray-100
            focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition" />
            <span asp-validation-for="Summary" class="text-red-500 text-sm"></span>
        </div>

        <!-- Customer Dropdown -->
        <div>
            <label asp-for="CustomerId" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Select Customer</label>
            <select asp-for="CustomerId" asp-items="ViewBag.CustomerId"
                    class="w-full px-4 py-2 rounded-lg border border-gray-300 dark:border-gray-700
                bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-gray-100
                focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition">
                <option value="">-- Select Customer --</option>
            </select>
            <span asp-validation-for="CustomerId" class="text-red-500 text-sm"></span>
        </div>

        <!-- Submit -->
        <button type="submit"
                class="w-full py-3 rounded-lg bg-blue-600 hover:bg-blue-700
            text-white font-semibold transition">
            Create Appointment
        </button>

    </form>

    <div class="mt-6 text-center">
        <a asp-controller="Home" asp-action="Index"
               class="text-blue-600 dark:text-blue-400 hover:underline">
            Back to List
        </a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}