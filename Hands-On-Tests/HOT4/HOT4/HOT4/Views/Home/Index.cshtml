@model IEnumerable<Appointment>

@{
    ViewData["Title"] = "Appointments";
}

<div class="max-w-5xl mx-auto mt-10">

    <div class="flex items-center justify-between mb-6">
        <h1 class="text-3xl font-bold text-stone-800 ">
            Appointments
        </h1>
        <a asp-controller="Customer" asp-action="Create"
               class="px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white font-semibold transition">
            + Create Customer
        </a>
        <a asp-controller="Appointment" asp-action="Create"
               class="px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white font-semibold transition">
            + Create Appointment
        </a>
    </div>

    <div class="overflow-hidden rounded-xl shadow-lg bg-white dark:bg-gray-900">
        <table class="min-w-full divide-y divide-gray-300 dark:divide-gray-700">
            <thead class="bg-gray-100 dark:bg-gray-800">
                <tr>
                    <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700 dark:text-gray-300">Start Date</th>
                    <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700 dark:text-gray-300">Summary</th>
                    <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700 dark:text-gray-300">Customer</th>
                </tr>
            </thead>

            <tbody class="divide-y divide-gray-200 dark:divide-gray-800">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-gray-50 dark:hover:bg-gray-800 transition">
                        <td class="px-6 py-4 text-gray-800 dark:text-gray-100">
                            @item.StartDate.ToString("g")
                        </td>
                        <td class="px-6 py-4 text-gray-800 dark:text-gray-100">
                            @(item.Summary)
                        </td>

                        <td class="px-6 py-4 text-gray-800 dark:text-gray-100">
                            @(item.customer?.Username ?? "Unknown")
                        </td>

                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>