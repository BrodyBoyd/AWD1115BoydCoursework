@model IEnumerable<HOT4.Models.Appointment>

@{
    ViewData["Title"] = "Manage Appointments";
}

<div class="max-w-6xl mx-auto mt-10">

    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
        <h1 class="text-3xl font-bold text-stone-800">
            Appointment Management
        </h1>

        <div class="flex gap-3">
            <a asp-area="" asp-controller="Customer" asp-action="Create"
                   class="px-4 py-2 rounded-lg bg-emerald-600 hover:bg-emerald-700 text-white font-semibold transition">
                + New Customer
            </a>

            <a asp-area="" asp-controller="Appointment" asp-action="Create"
                   class="px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white font-semibold transition">
                + New Appointment
            </a>
        </div>
    </div>

    <!-- Table -->
    <div class="overflow-hidden rounded-xl shadow-lg bg-white">
        <table class="min-w-full divide-y divide-gray-300">
            <thead class="bg-gray-100">
                <tr>
                    <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">Start Date</th>
                    <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">Summary</th>
                    <th class="px-6 py-3 text-left text-sm font-semibold text-gray-700">Customer</th>
                    <th class="px-6 py-3 text-right text-sm font-semibold text-gray-700">Actions</th>
                </tr>
            </thead>

            <tbody class="divide-y divide-gray-200">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-gray-50 transition">
                        <td class="px-6 py-4 text-gray-800">
                            @item.StartDate.ToString("g")
                        </td>

                        <td class="px-6 py-4 text-gray-800">
                            @item.Summary
                        </td>

                        <td class="px-6 py-4">
                            <span class="px-3 py-1 rounded-full bg-blue-100 text-blue-700 text-sm font-medium">
                                @(item.customer?.Username ?? "Unknown")
                            </span>
                        </td>

                        <td class="px-6 py-4 text-right space-x-3">
                            <a asp-area="Admin" asp-controller="Appointment" asp-action="Edit" asp-route-id="@item.Id"
                               class="text-blue-600 hover:underline">Edit</a>

                            <a asp-area="Admin" asp-controller="Appointment" asp-action="Delete" asp-route-id="@item.Id"
                               class="text-red-600 hover:underline">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>
