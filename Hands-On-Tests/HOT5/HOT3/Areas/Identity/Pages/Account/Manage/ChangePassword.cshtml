@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Change password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<h3 class="text-2xl font-semibold text-gray-100 mb-6">@ViewData["Title"]</h3>

@* <partial name="_StatusMessage" for="StatusMessage" /> *@

<div class="max-w-xl">
    <form id="change-password-form" method="post" class="space-y-6 bg-gray-900 p-6 rounded-xl border border-gray-800 shadow-lg">
        
        <div asp-validation-summary="ModelOnly" class="text-red-400 text-sm" role="alert"></div>

        <!-- Old Password -->
        <div>
            <label asp-for="Input.OldPassword" class="block text-sm font-medium text-gray-300 mb-1"></label>
            <input asp-for="Input.OldPassword"
                   autocomplete="current-password"
                   aria-required="true"
                   placeholder="Enter your current password"
                   class="w-full rounded-lg bg-gray-800 border border-gray-700 text-gray-100 placeholder-gray-500 focus:ring-indigo-500 focus:border-indigo-500 px-4 py-2" />
            <span asp-validation-for="Input.OldPassword" class="text-red-400 text-sm"></span>
        </div>

        <!-- New Password -->
        <div>
            <label asp-for="Input.NewPassword" class="block text-sm font-medium text-gray-300 mb-1"></label>
            <input asp-for="Input.NewPassword"
                   autocomplete="new-password"
                   aria-required="true"
                   placeholder="Enter a new password"
                   class="w-full rounded-lg bg-gray-800 border border-gray-700 text-gray-100 placeholder-gray-500 focus:ring-indigo-500 focus:border-indigo-500 px-4 py-2" />
            <span asp-validation-for="Input.NewPassword" class="text-red-400 text-sm"></span>
        </div>

        <!-- Confirm Password -->
        <div>
            <label asp-for="Input.ConfirmPassword" class="block text-sm font-medium text-gray-300 mb-1"></label>
            <input asp-for="Input.ConfirmPassword"
                   autocomplete="new-password"
                   aria-required="true"
                   placeholder="Confirm your new password"
                   class="w-full rounded-lg bg-gray-800 border border-gray-700 text-gray-100 placeholder-gray-500 focus:ring-indigo-500 focus:border-indigo-500 px-4 py-2" />
            <span asp-validation-for="Input.ConfirmPassword" class="text-red-400 text-sm"></span>
        </div>

        <button type="submit"
                class="w-full py-3 rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white font-semibold transition">
            Update Password
        </button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}