@model HOT5.Models.Product

@{
    ViewData["Title"] = "Delete Product";
}

<div class="max-w-3xl mx-auto px-6 py-12">

    <h1 class="text-4xl font-bold text-white mb-6">Delete Product</h1>

    <div class="bg-gray-900 border border-gray-800 rounded-2xl shadow-xl p-8">

        <h3 class="text-xl text-red-400 font-semibold mb-6">
            Are you sure you want to delete this product?
        </h3>

        <!-- Product Preview -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">

            <!-- Image -->
            <div class="flex items-center justify-center bg-gray-800 rounded-xl p-4">
                <img src="@Model.ImageUrl"
                     alt="@Model.Name"
                     class="max-h-40 object-contain rounded-lg" />
            </div>

            <!-- Details -->
            <div class="md:col-span-2 space-y-3 text-gray-300">

                <div>
                    <span class="font-semibold text-gray-400">Name:</span>
                    <p class="text-white">@Model.Name</p>
                </div>

                <div>
                    <span class="font-semibold text-gray-400">Description:</span>
                    <p>@Model.Description</p>
                </div>

                <div>
                    <span class="font-semibold text-gray-400">Stock:</span>
                    <p>@Model.StockQuantity</p>
                </div>

                <div>
                    <span class="font-semibold text-gray-400">Price:</span>
                    <p class="text-blue-400 font-semibold">@Model.Price.ToString("C")</p>
                </div>

                <div>
                    <span class="font-semibold text-gray-400">Category:</span>
                    <p>@Model.Category?.Name</p>
                </div>

            </div>
        </div>

        <!-- Delete Form -->
        <form asp-action="Delete" class="space-y-4">
            <input type="hidden" asp-for="ProductId" />

            <button type="submit"
                    class="w-full bg-red-600 hover:bg-red-700 text-white font-semibold py-3 rounded-lg transition">
                Delete Product
            </button>

            <a asp-action="Index"
               class="block text-center text-gray-400 hover:text-white transition">
                Cancel and go back
            </a>
        </form>

    </div>

</div>