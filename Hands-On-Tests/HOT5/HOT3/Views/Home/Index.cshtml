@model IEnumerable<Product>

@{
    ViewData["Title"] = "Home";
    var categories = ViewBag.Categories as List<Category>;
    var currentCategory = ViewBag.CurrentCategory as int?;
    var searchString = ViewBag.SearchString as string;

}

<div class="max-w-7xl mx-auto px-6 py-10">

    <!-- Page Title -->
    <h1 class="text-4xl font-bold text-white mb-8">Explore Our Products</h1>

    <!-- Search + Category Filter -->
    <form asp-action="Index" method="get" class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-10">

        <!-- Search Bar -->
        <div class="col-span-2 flex items-center bg-gray-800 border border-gray-700 rounded-xl px-4 py-3">
            <svg xmlns="http://www.w3.org/2000/svg"
                 fill="none" viewBox="0 0 24 24"
                 stroke-width="1.5" stroke="currentColor"
                 class="w-6 h-6 text-gray-400 mr-3">
                <path stroke-linecap="round" stroke-linejoin="round"
                      d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196
                      5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
            </svg>

            <input type="text"
                   name="searchString"
                   placeholder="Search products..."
                   class="w-full bg-transparent text-gray-200 placeholder-gray-400 focus:outline-none" />
        </div>

        <!-- Category Dropdown -->
        
        <select name="CategoryId"
            onchange="this.form.submit()">
            <option value="">All Categories</option>
            @if (categories != null)
            {
                @foreach (var category in categories)
                {
                    <option value="@category.CategoryId" selected="@(currentCategory == category.CategoryId)">
                        @category.Name
                    </option>
                }    
            }
        </select>

        <!-- Submit Button -->
        <button type="submit"
                class="md:col-span-3 bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-xl transition">
            Apply Filters
        </button>
    </form>

    <!-- Product Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-8">

        @foreach (var product in Model)
        {
            <div class="bg-gray-900 rounded-2xl shadow-xl border border-gray-800 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 overflow-hidden">

                <!-- Image -->
                <div class="w-full h-64 bg-gray-800 flex items-center justify-center p-4">
                    <img src="@product.ImageUrl"
                         alt="@product.Name"
                         class="max-h-full max-w-full object-contain cover" />
                </div>

                <!-- Content -->
                <div class="p-6 space-y-3 text-gray-200">
                    <h2 class="text-xl font-semibold text-white">@product.Name</h2>

                    <p class="text-gray-400 text-sm leading-relaxed">
                        @product.Description
                    </p>

                    <p class="text-lg font-bold text-blue-400">
                        @product.Price.ToString("C")
                    </p>
                    <p class="text-lg font-bold text-blue-400">
                        Stock: @product.StockQuantity
                    </p>
                    <a asp-action="Details"
                       asp-route-id="@product.ProductId"
                       asp-route-slug="@product.Slug"
                       class="block w-full text-center bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 rounded-lg transition">
                        Details
                    </a>
                    <form asp-controller="Cart" asp-action="AddToCart" method="post">
                        <input type="hidden" name="productId" value="@product.ProductId" />
                        <button type="submit" 
                           class="block w-full text-center bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 rounded-lg transition">
                            Add to Cart
                        </button>
                    </form>
                    
                </div>
            </div>
        }
        
    </div>
    <div class="flex justify-center gap-4 mt-6">
            @if (ViewBag.CurrentPage > 1)
            {
                <a class="px-4 py-2 bg-gray-800 text-white rounded"
                   href="@Url.Action("Index", new { 
                       categoryId = ViewBag.CurrentCategory,
                       searchString = ViewBag.CurrentSearch,
                       page = ViewBag.CurrentPage - 1
                   })">
                    Previous
                </a>
            }

            @if (ViewBag.CurrentPage < ViewBag.TotalPages)
            {
                <a class="px-4 py-2 bg-gray-800 text-white rounded"
                   href="@Url.Action("Index", new { 
                       categoryId = ViewBag.CurrentCategory,
                       searchString = ViewBag.CurrentSearch,
                       page = ViewBag.CurrentPage + 1
                   })">
                    Next
                </a>
            }
        </div>

</div>
