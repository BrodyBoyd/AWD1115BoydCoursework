@model Product

<div class="max-w-5xl mx-auto py-10 px-4">

    <!-- Back Link -->
    <a asp-action="Index"
       class="inline-block mb-6 text-blue-600 hover:text-blue-700 font-medium">
        ← Back to Products
    </a>

    <div class="bg-gray-900 rounded-2xl shadow-xl border border-gray-800 overflow-hidden">

        <div class="grid grid-cols-1 lg:grid-cols-2">

            <!-- Image Section -->
            <div class="bg-gray-800 flex items-center justify-center p-6 h-96 lg:h-full">
                <img src="@Url.Content(Model.ImageUrl)"
                     alt="@Model.Name"
                     class="max-h-full max-w-full object-contain" />
            </div>

            <!-- Content Section -->
            <div class="p-8 space-y-6 text-gray-200">

                <h1 class="text-3xl font-bold text-white">@Model.Name</h1>

                <p class="text-gray-400 leading-relaxed">
                    @Model.Description
                </p>

                <p class="text-2xl font-bold text-blue-400">
                    @Model.Price.ToString("C")
                </p>

                <!-- Stock Badge -->
                <span class="inline-block text-sm font-medium text-blue-500 bg-blue-100/10 border border-blue-500/30 px-3 py-1 rounded-full">
                    @Model.StockQuantity in stock
                </span>

                <!-- Action Buttons -->
                <div class="space-y-3 pt-4">
                    <form asp-controller="Cart" asp-action="AddToCart" method="post">
                        <input type="hidden" name="productId" value="@Model.ProductId" />
                        <button type="submit"
                           class="block w-full text-center bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-lg transition">
                            Add to Cart
                        </button>
                    </form>

                    <a asp-action="Index"
                       class="block w-full text-center bg-gray-700 hover:bg-gray-600 text-gray-200 font-semibold py-3 rounded-lg transition">
                        Continue Shopping
                    </a>
                </div>

            </div>
        </div>
    </div>
</div>