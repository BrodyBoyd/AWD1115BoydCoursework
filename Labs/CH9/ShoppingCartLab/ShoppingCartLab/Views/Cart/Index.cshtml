@model ShoppingCartLab.ViewModels.CartViewModel

<div class="max-w-7xl mx-auto py-10 px-4">

    <h1 class="text-3xl font-bold text-gray-900 mb-8">Your Cart</h1>

    @if (Model.IsEmpty)
    {
        <p class="text-gray-600 text-lg">Your cart is empty.</p>

        <a asp-action="Index" asp-controller="Product"
           class="inline-block mt-4 bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-lg transition">
            Browse Products
        </a>
    }
    else
    {
        <!-- Two-column layout -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

            <!-- LEFT: Cart Items -->
            <div class="lg:col-span-2 space-y-6">

                @foreach (var item in Model.Items)
                {
                    <div class="bg-gray-900 rounded-xl border border-gray-800 shadow-lg p-4 flex gap-4 items-center">

                        <!-- Image -->
                        <div class="w-28 h-28 bg-gray-800 flex items-center justify-center rounded-lg overflow-hidden">
                            <img src="@Url.Content(item.ImageUrl)"
                                 alt="@item.ProductName"
                                 class="max-h-full max-w-full object-contain" />
                        </div>

                        <!-- Info -->
                        <div class="flex-1 text-gray-200 space-y-1">
                            <h2 class="text-xl font-semibold text-white">@item.ProductName</h2>

                            <p class="text-blue-400 font-bold text-lg">
                                @item.Price.ToString("C")
                            </p>

                            <!-- Update Quantity -->
                            <form asp-action="UpdateQuantity" method="post" class="flex items-center gap-2 mt-2">
                                <input type="hidden" name="productId" value="@item.ProductId" />

                                <input type="number"
                                       name="quantity"
                                       value="@item.Quantity"
                                       min="1"
                                       class="w-20 bg-gray-800 border border-gray-700 text-gray-200 rounded-md px-2 py-1 focus:outline-none focus:ring-2 focus:ring-blue-500" />

                                <button type="submit"
                                        class="bg-blue-600 hover:bg-blue-700 text-white px-3 py-1 rounded-md text-sm transition">
                                    Update
                                </button>
                            </form>

                            <p class="text-gray-300 text-sm">
                                Line Total:
                                <span class="font-semibold">@item.TotalPrice.ToString("C")</span>
                            </p>
                        </div>

                        <!-- Remove Button -->
                        <form asp-action="RemoveFromCart"
                              method="post">
                            <input type="hidden" name="productId" value="@item.ProductId" />
                            <button class="text-red-400 hover:text-red-500 font-semibold">
                                Remove
                            </button>
                        </form>
                    </div>
                }
                <form asp-action="ClearCart"
                      method="post">
                    <button class="text-red-400 hover:text-red-500 font-semibold">
                        Clear Cart
                    </button>
                </form>

            </div>

            <!-- RIGHT: Summary -->
            <div class="bg-white rounded-xl shadow-md border border-gray-200 p-6 h-fit">

                <h2 class="text-2xl font-bold text-gray-900 mb-4">Order Summary</h2>

                <div class="flex justify-between text-lg font-medium text-gray-700">
                    <span>Subtotal</span>
                    <span>@Model.SubTotal.ToString("C")</span>
                </div>

                <div class="flex justify-between text-lg font-medium text-gray-700 mt-2">
                    <span>Tax (7%)</span>
                    <span>@Model.Tax.ToString("C")</span>
                </div>

                <div class="flex justify-between text-xl font-bold text-gray-900 mt-4">
                    <span>Total</span>
                    <span>@Model.Total.ToString("C")</span>
                </div>

                <a asp-action="Checkout"
                   class="block w-full mt-6 text-center bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-lg transition">
                    Proceed to Checkout
                </a>

                <a asp-action="Index" asp-controller="Product"
                   class="block w-full mt-3 text-center bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold py-3 rounded-lg transition">
                    Continue Shopping
                </a>
            </div>

        </div>
    }
</div>