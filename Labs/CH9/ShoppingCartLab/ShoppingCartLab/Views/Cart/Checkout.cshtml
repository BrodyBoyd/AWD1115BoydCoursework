@model CartViewModel

@{
    ViewData["Title"] = "Checkout";
}

<div class="max-w-7xl mx-auto py-10 px-4">

    <h1 class="text-3xl font-bold text-gray-900 mb-8">Checkout</h1>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

        <!-- LEFT: Customer Info + Items -->
        <div class="lg:col-span-2 space-y-10">

            <!-- Customer Info -->
            <div class="bg-white rounded-xl shadow-md border border-gray-200 p-6">
                <h2 class="text-2xl font-bold text-gray-900 mb-4">Contact Information</h2>

                <form asp-action="PlaceOrder" method="post" class="space-y-4">

                    <!-- Simple Address Field -->
                    <div>
                        <label class="block text-gray-700 font-medium mb-1">Address</label>
                        <input type="text" name="Address"
                               placeholder="123 Main St, Springfield, IL"
                               class="w-full border border-gray-300 rounded-lg px-4 py-2 
                                      focus:ring-2 focus:ring-blue-500 focus:outline-none"
                               required />
                    </div>

                    <button type="submit"
                            class="w-full mt-6 bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-lg transition">
                        Place Order
                    </button>

                </form>
                <a asp-action="Index" class="flex">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
                    </svg>
                    Back to Cart
                </a>
            </div>

            <!-- Cart Items (Dark Theme) -->
            <div class="space-y-6">
                @foreach (var item in Model.Items)
                {
                    <div class="bg-gray-900 rounded-xl border border-gray-800 shadow-lg p-4 flex gap-4 items-center">

                        <div class="w-28 h-28 bg-gray-800 flex items-center justify-center rounded-lg overflow-hidden">
                            <img src="@Url.Content(item.ImageUrl)"
                                 alt="@item.ProductName"
                                 class="max-h-full max-w-full object-contain" />
                        </div>

                        <div class="flex-1 text-gray-200 space-y-1">
                            <h2 class="text-xl font-semibold text-white">@item.ProductName</h2>

                            <p class="text-blue-400 font-bold text-lg">
                                @item.Price.ToString("C")
                            </p>

                            <p class="text-gray-300 text-sm">
                                Quantity: <span class="font-semibold">@item.Quantity</span>
                            </p>

                            <p class="text-gray-300 text-sm">
                                Line Total: <span class="font-semibold">@item.TotalPrice.ToString("C")</span>
                            </p>
                        </div>
                    </div>
                }
            </div>

        </div>

        <!-- RIGHT: Summary -->
        <div class="bg-white rounded-xl shadow-md border border-gray-200 p-6 h-fit">

            <h2 class="text-2xl font-bold text-gray-900 mb-4">Order Summary</h2>

            <div class="space-y-4 mb-6">
                @foreach (var item in Model.Items)
                {
                    <div class="flex justify-between items-center">
                        <div>
                            <p class="text-gray-800 font-medium">@item.ProductName</p>
                            <p class="text-gray-500 text-sm">Qty: @item.Quantity</p>
                        </div>
                        <p class="text-gray-800 font-semibold">@item.TotalPrice.ToString("C")</p>
                    </div>
                }
            </div>

            <div class="flex justify-between text-lg font-medium text-gray-700">
                <span>Subtotal</span>
                <span>@Model.SubTotal.ToString("C")</span>
            </div>

            <div class="flex justify-between text-lg font-medium text-gray-700 mt-2">
                <span>Tax (7%)</span>
                <span>@Model.Tax.ToString("C")</span>
            </div>

            <div class="flex justify-between text-xl font-bold text-gray-900 mt-4">
                <span>Total</span>
                <span>@Model.Total.ToString("C")</span>
            </div>

        </div>

    </div>
</div>