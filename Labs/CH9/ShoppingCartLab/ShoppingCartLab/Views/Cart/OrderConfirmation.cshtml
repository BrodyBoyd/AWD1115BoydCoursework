@model ShoppingCartLab.Models.Order

<div class="max-w-4xl mx-auto py-16 px-4 text-center">

    <!-- Success Icon -->
    <div class="mx-auto mb-6 flex items-center justify-center w-20 h-20 rounded-full bg-green-100">
        <svg class="w-12 h-12 text-green-600" fill="none" stroke="currentColor" stroke-width="2"
             viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M5 13l4 4L19 7" />
        </svg>
    </div>

    <h1 class="text-4xl font-bold text-gray-900 mb-4">Order Confirmed</h1>

    <p class="text-gray-600 text-lg max-w-xl mx-auto">
        Thank you for your purchase! Your order has been successfully placed.
    </p>

    <!-- Order Info -->
    <div class="mt-10 text-left space-y-6">

        <div class="bg-white rounded-xl shadow-md border border-gray-200 p-6">
            <h2 class="text-2xl font-bold text-gray-900 mb-4">Order Details</h2>

            <p class="text-gray-700"><span class="font-semibold">Order ID:</span> @Model.OrderId</p>
            <p class="text-gray-700"><span class="font-semibold">Order Date:</span> @Model.OrderDate.ToShortDateString()</p>
            <p class="text-gray-700"><span class="font-semibold">Status:</span> @Model.Status</p>

            @if (!string.IsNullOrWhiteSpace(Model.ShippingAddress))
            {
                <p class="text-gray-700"><span class="font-semibold">Shipping Address:</span> @Model.ShippingAddress</p>
            }
        </div>

        <!-- Items -->
        <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-4">Items in Your Order</h2>

            <div class="space-y-4">
                @foreach (var item in Model.OrderItems)
                {
                    <div class="bg-gray-900 rounded-xl border border-gray-800 shadow p-4 flex gap-4 items-center">

                        <div class="w-20 h-20 bg-gray-800 flex items-center justify-center rounded-lg overflow-hidden">
                            <img src="@Url.Content(item.Product.ImageUrl)"
                                 alt="@item.Product.Name"
                                 class="max-h-full max-w-full object-contain" />
                        </div>

                        <div class="flex-1 text-gray-200">
                            <p class="text-lg font-semibold text-white">@item.Product.Name</p>
                            <p class="text-gray-400 text-sm">Quantity: @item.Quantity</p>
                        </div>

                        <p class="text-blue-400 font-bold text-lg">
                            @item.TotalPrice.ToString("C")
                        </p>
                    </div>
                }
            </div>
        </div>

        <!-- Summary -->
        <div class="bg-white rounded-xl shadow-md border border-gray-200 p-6">
            <h2 class="text-2xl font-bold text-gray-900 mb-4">Order Summary</h2>

            <div class="flex justify-between text-xl font-bold text-gray-900">
                <span>Total Amount</span>
                <span>@Model.TotalAmount.ToString("C")</span>
            </div>
        </div>

        <!-- Continue Shopping -->
        <div class="text-center mt-10">
            <a asp-controller="Product" asp-action="Index"
               class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-6 rounded-lg transition">
                Continue Shopping
            </a>
        </div>

    </div>
</div>