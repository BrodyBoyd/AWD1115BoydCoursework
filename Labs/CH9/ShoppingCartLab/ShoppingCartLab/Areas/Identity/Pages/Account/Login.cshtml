@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="min-h-screen flex items-center justify-center bg-gray-50 py-12 px-4">
    <div class="w-full max-w-md bg-white shadow-lg rounded-xl p-8">
        <h1 class="text-2xl font-bold text-gray-800 mb-6 text-center">@ViewData["Title"]</h1>

        <form id="account" method="post" class="space-y-5">
            <h2 class="text-lg font-semibold text-gray-700">Use a local account to log in</h2>

            <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm"></div>

            <div>
                <label asp-for="Input.Email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                <input asp-for="Input.Email"
                       class="w-full rounded-lg border-gray-300 focus:ring-blue-500 focus:border-blue-500"
                       autocomplete="username" aria-required="true" placeholder="name@example.com" />
                <span asp-validation-for="Input.Email" class="text-red-600 text-sm"></span>
            </div>

            <div>
                <label asp-for="Input.Password" class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                <input asp-for="Input.Password"
                       class="w-full rounded-lg border-gray-300 focus:ring-blue-500 focus:border-blue-500"
                       autocomplete="current-password" aria-required="true" placeholder="password" />
                <span asp-validation-for="Input.Password" class="text-red-600 text-sm"></span>
            </div>

            <div class="flex items-center">
                <input asp-for="Input.RememberMe"
                       class="h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" />
                <label asp-for="Input.RememberMe" class="ml-2 block text-sm text-gray-700">
                    @Html.DisplayNameFor(m => m.Input.RememberMe)
                </label>
            </div>

            <button id="login-submit"
                    type="submit"
                    class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 rounded-lg transition">
                Log in
            </button>

            <div class="text-sm space-y-2 pt-2">
                <p>
                    <a id="forgot-password" asp-page="./ForgotPassword"
                       class="text-blue-600 hover:text-blue-700">Forgot your password?</a>
                </p>
                <p>
                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl"
                       class="text-blue-600 hover:text-blue-700">Register as a new user</a>
                </p>
                <p>
                    <a id="resend-confirmation" asp-page="./ResendEmailConfirmation"
                       class="text-blue-600 hover:text-blue-700">Resend email confirmation</a>
                </p>
            </div>
        </form>

        <div class="mt-10">
            <h3 class="text-lg font-semibold text-gray-700 mb-2">Use another service to log in</h3>

            @if ((Model.ExternalLogins?.Count ?? 0) == 0)
            {
                <p class="text-sm text-gray-600">
                    There are no external authentication services configured.
                    See this <a class="text-blue-600 hover:text-blue-700"
                                href="https://go.microsoft.com/fwlink/?LinkID=532715">article</a>.
                </p>
            }
            else
            {
                <form id="external-account"
                      asp-page="./ExternalLogin"
                      asp-route-returnUrl="@Model.ReturnUrl"
                      method="post"
                      class="space-y-3">

                    @foreach (var provider in Model.ExternalLogins!)
                    {
                        <button type="submit"
                                name="provider"
                                value="@provider.Name"
                                class="w-full bg-gray-800 hover:bg-gray-900 text-white py-2 rounded-lg font-medium transition"
                                title="Log in using your @provider.DisplayName account">
                            @provider.DisplayName
                        </button>
                    }
                </form>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}