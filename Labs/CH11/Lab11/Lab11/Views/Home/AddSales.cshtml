@model Sales

<div class="max-w-xl mx-auto px-6 py-12">

    <h1 class="text-4xl font-bold text-white mb-8">Add Sales</h1>

    <div class="bg-gray-900 border border-gray-800 rounded-2xl shadow-xl p-8">

        <form asp-action="AddSales" method="post" class="space-y-6">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="All" class="text-red-400 text-sm"></div>


            <!-- Quarter -->
            <div>
                <label class="block text-gray-300 font-medium mb-1">Quarter</label>
                <select asp-for="Quarter" name="Quarter"
                        class="w-full bg-gray-800 border border-gray-700 text-gray-200 rounded-lg px-4 py-2
                    focus:outline-none focus:ring-2 focus:ring-blue-600">
                    <option value="1">Q1</option>
                    <option value="2">Q2</option>
                    <option value="3">Q3</option>
                    <option value="4">Q4</option>
                </select>
                <span asp-validation-for="Quarter" class="text-red-400 text-sm"></span>

            </div>

            <!-- Year -->
            <div>
                <label class="block text-gray-300 font-medium mb-1">Year</label>
                <input type="number"
                       asp-for="Year"
                       class="w-full bg-gray-800 border border-gray-700 text-gray-200 rounded-lg px-4 py-2
                focus:outline-none focus:ring-2 focus:ring-blue-600"
                       placeholder="2026" />
                <span asp-validation-for="Year" class="text-red-400 text-sm"></span>

            </div>

            <!-- Amount -->
            <div>
                <label class="block text-gray-300 font-medium mb-1">Amount</label>
                <input type="number"
                       asp-for="Amount"
                       step="0.01"
                       class="w-full bg-gray-800 border border-gray-700 text-gray-200 rounded-lg px-4 py-2
                focus:outline-none focus:ring-2 focus:ring-blue-600"
                       placeholder="0.00" />
                <span asp-validation-for="Amount" class="text-red-400 text-sm"></span>

            </div>

            <!-- Employee -->
            <div>
                <label asp-for="EmployeeId" class="block text-gray-300 font-medium mb-1">Employee</label>
                <select asp-for="EmployeeId" name="EmployeeId"
                        asp-items="ViewBag.Employees"
                        class="w-full bg-gray-800 border border-gray-700 text-gray-200 rounded-lg px-4 py-2
                    focus:outline-none focus:ring-2 focus:ring-blue-600">
                        <option value="">-- Select Employee --</option>
                </select>
                <span asp-validation-for="EmployeeId" class="text-red-400 text-sm"></span>

            </div>

            <!-- Submit -->
            <button type="submit"
                    class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-lg transition">
                Add Sale
            </button>

        </form>

    </div>

</div>

                    
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const form = document.querySelector('form');

            // Fields that require server-side validation on blur
            const fieldsToValidate = ['Quarter', 'Year', 'Amount', 'EmployeeId'];

            /**
             * Updates the visual state of a form field based on validation result.
             * @@param {HTMLElement} field - The input element to style
             * @@param {HTMLElement} errorSpan - The span element for error messages
             * @@param {boolean} isValid - Whether the field passed validation
             * @@param {string[]} errors - Array of error messages to display
             */
            const setFieldState = (field, errorSpan, isValid, errors = []) => {
                // Toggle border color: red for invalid, gray for valid
                field.classList.toggle('border-red-500', !isValid);
                field.classList.toggle('border-gray-300', isValid);

                if (errorSpan) {
                    // Show error messages or clear them
                    errorSpan.textContent = isValid ? '' : errors.join(', ');
                    errorSpan.classList.toggle('hidden', isValid);
                }
            };

            // Use event delegation with capture phase to handle blur on all form fields
            //Event travels down from form → target element
            form.addEventListener('blur', async (e) => {
                const fieldName = e.target.id;

                // Only validate fields in our allowlist
                if (!fieldsToValidate.includes(fieldName)) return;

                // Build payload with current form values for server-side validation
                const data = {
                    fieldName,
                    Quarter: parseInt(form.querySelector('[name="Quarter"]')?.value) || null,
                    Year: parseInt(form.querySelector('[name="Year"]')?.value) || null,
                    Amount: (form.querySelector('[name="Amount"]')?.value !== '') ? parseFloat(form.querySelector('[name="Amount"]')?.value) : null,
                    EmployeeId: (form.querySelector('[name="EmployeeId"]')?.value !== '') ? parseInt(form.querySelector('[name="EmployeeId"]')?.value) : null
                };

                try {
                    // Send validation request to server
                    const response = await fetch('@Url.Action("ValidateSaleField", "Home")', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            // Include anti-forgery token for security
                            'RequestVerificationToken': form.querySelector('[name="__RequestVerificationToken"]')?.value
                        },
                        body: JSON.stringify(data)
                    });

                    if (!response.ok) {
                        console.error('Validation request failed', response.status, await response.text());
                        return;
                    }

                    // Destructure response and update field styling
                    const { isValid, errors } = await response.json();
                    setFieldState(e.target, document.querySelector(`[data-valmsg-for="${fieldName}"]`), isValid, errors);
                } catch (error) {
                    console.error('Validation error:', error);
                }
            }, true); // 'true' allows blur event from child elements to be captured at the form level
        });
    </script>
}