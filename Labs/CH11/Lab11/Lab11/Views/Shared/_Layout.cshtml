<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>@ViewBag.Title</title>
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
</head>

<body class="bg-gray-950 text-gray-200">

    <!-- NAVBAR -->
    <nav class="px-6 py-4 border-b border-gray-800 bg-gray-900 flex items-center gap-6 shadow-lg">

        <a asp-action="Index"
               class="text-gray-300 hover:text-white font-medium transition">
            Home
        </a>

        <a asp-action="AddSales"
               class="text-gray-300 hover:text-white font-medium transition">
            Add Sales
        </a>

        <a asp-action="AddEmployee"
               class="text-gray-300 hover:text-white font-medium transition">
            Add Employee
        </a>

    </nav>

    <!-- MAIN CONTENT -->
    <main class="px-6 py-10 max-w-6xl mx-auto">
        @RenderBody()
    </main>
    @RenderSection("Scripts", required: false)

</body>
</html>