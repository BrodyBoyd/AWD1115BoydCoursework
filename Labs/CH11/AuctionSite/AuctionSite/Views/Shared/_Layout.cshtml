@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>@ViewBag.Title</title>
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />

</head>

@functions {
    string ActiveClass(string controller, string action = "Index", string area = "")
    {
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
        var currentArea = ViewContext.RouteData.Values["area"]?.ToString() ?? "";

        if (currentController == controller &&
        currentAction == action &&
        currentArea == area)
        {
            return "border-b-2 border-blue-500";
        }

        return "";
    }
}
@{
    string currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    string currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    string currentArea = ViewContext.RouteData.Values["area"]?.ToString();
}
<nav class="bg-white border-b border-[#D9D4CC] shadow-sm">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">

        <!-- Left: Logo + Nav Links -->
        <div class="flex items-center gap-10">

            <!-- Logo / Brand -->
            <a asp-action="Index"
                   class="text-2xl font-bold text-[#1A1A1A] tracking-tight hover:text-[#C6A667] transition">
                Local Common Goods
            </a>

            <!-- Nav Links -->
            <div class="flex items-center gap-6 text-[#1A1A1A] font-medium">

                <a asp-action="Index"
                       class="hover:text-[#C6A667] transition @ActiveClass("Listings", "Index")">
                    All Listings
                </a>

                <a asp-action="MyAuctions" asp-route-userId="@UserManager.GetUserId(User)"
                       class="hover:text-[#C6A667] transition @ActiveClass("Listings", "MyAuctions")">
                    My Auctions
                </a>

                <a asp-action="MyBids"
                       class="hover:text-[#C6A667] transition @ActiveClass("Listings", "MyBids")">
                    My Bids
                </a>

                <a asp-action="Create"
                       class="hover:text-[#C6A667] transition @ActiveClass("Listings", "Create")">
                    Create Listing
                </a>
            </div>
        </div>

        <!-- Right: Login Partial -->
        <div class="flex items-center">
            <partial name="_LoginPartial" />
        </div>

    </div>
</nav>
<body>
    @RenderBody()
</body>
@RenderSection("Scripts", required: false)

</html>
