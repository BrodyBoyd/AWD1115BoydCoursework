@model IEnumerable<Listing>

@{
    var currentPage = Context.Request.Query["page"].ToString() ?? "1";
    var currentSort = Context.Request.Query["sortby"].ToString() ?? "title";
    var currentSearch = Context.Request.Query["search"].ToString();
    var currentType = Context.Request.Query["type"].ToString() ?? "all";
    var currentCategory = ViewBag.CurrentCategory as string;
    int pageNum = int.TryParse(currentPage, out var p) ? p : 1;
    var categories = ViewBag.Categories as List<string>;
}

<div class="min-h-screen bg-[#F7F4EF]">

    <!-- Page Header -->
    <div class="border-b border-[#D9D4CC] bg-white">
        <div class="max-w-7xl mx-auto px-6 py-10">
            <h1 class="text-4xl font-bold text-[#1A1A1A] tracking-tight">
                All Auction Listings
            </h1>
            <p class="mt-2 text-lg text-[#4A4A4A]">
                Explore all available items currently open for bidding.
            </p>
        </div>
    </div>

    <!-- Filters -->
    <div class="max-w-7xl mx-auto px-6 py-6">
        <div class="flex flex-wrap gap-4 items-center">

            <form method="get" class="flex flex-wrap gap-4 items-center">

                <!-- Search -->
                <input type="text"
                       name="search"
                       value="@currentSearch"
                       placeholder="Search listings…"
                       class="w-full md:w-80 px-4 py-2 border border-[#D9D4CC] rounded-md bg-white focus:ring-2 focus:ring-[#C6A667]" />

                <button type="submit"
                        class="px-4 py-2 bg-[#1A1A1A] text-white rounded-md hover:bg-black transition">
                    Search
                </button>

                <!-- Category -->
                <select name="category"
                        onchange="this.form.submit()"
                        class="px-4 py-2 border border-[#D9D4CC] rounded-md bg-white focus:ring-2 focus:ring-[#C6A667]">
                    <option value="">All Categories</option>

                    @if (categories != null)
                    {
                        foreach (var category in categories)
                        {
                            <option value="@category" selected="@(currentCategory == category)">
                                @category
                            </option>
                        }
                    }
                </select>
            </form>

            <!-- Sort Buttons -->
            <div class="flex gap-3">
                <a class="px-4 py-2 bg-[#C6A667] text-white rounded-md hover:bg-[#b09055] transition"
                   href="@Url.Action("Index", new {
                       category = currentCategory,
                       search = currentSearch,
                       sortby = "price",
                       page = 1,
                       type = currentType
                   })">
                    Price ↓
                </a>

                <a class="px-4 py-2 bg-[#C6A667] text-white rounded-md hover:bg-[#b09055] transition"
                   href="@Url.Action("Index", new {
                       category = currentCategory,
                       search = currentSearch,
                       sortby = "title",
                       page = 1,
                       type = currentType
                   })">
                    Title ↓
                </a>

                <a class="px-4 py-2 bg-[#C6A667] text-white rounded-md hover:bg-[#b09055] transition"
                   href="@Url.Action("Index", new {
                       category = currentCategory,
                       search = currentSearch,
                       sortby = "description",
                       page = 1,
                       type = currentType  
                   })">
                    Description ↓
                </a>
            </div>


            <div class="flex gap-3 ml-4">
                <a class="px-4 py-2 bg-[#C6A667] text-white rounded-md hover:bg-[#b09055] transition"
                   href="@Url.Action("Index", new {
                       category = currentCategory,
                       search = currentSearch,
                       sortby = "title",
                       page = 1,
                       type = "active"
                   })">
                    All Active Listings 
                </a>

                <a class="px-4 py-2 bg-[#C6A667] text-white rounded-md hover:bg-[#b09055] transition"
                   href="@Url.Action("Index", new {
                       category = currentCategory,
                       search = currentSearch,
                       sortby = "title",
                       page = 1,
                       type = "all"   
                   })">
                    All Listings
                </a>
            </div>

        </div>
    </div>

    <!-- Listings Grid -->
    <div class="max-w-7xl mx-auto px-6 pb-20">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">

            @foreach (var item in Model)
            {
                <div class="bg-white rounded-xl shadow-sm border border-[#E5E1DA] hover:shadow-md transition overflow-hidden">

                    <!-- Image -->
                    <div class="relative">
                        <img src="~/images/@item.ImageUrl" class="w-full h-56 object-cover" />

                        <div class="absolute top-3 left-3 bg-[#C6A667] text-white text-xs font-semibold px-3 py-1 rounded-full shadow">
                            @item.Category
                        </div>
                    </div>

                    <!-- Content -->
                    <div class="p-5">
                        <h2 class="text-xl font-semibold text-[#1A1A1A]">
                            @item.Title
                        </h2>

                        <p class="mt-2 text-sm text-[#4A4A4A] line-clamp-2">
                            @item.Description
                        </p>

                        <div class="mt-4 flex justify-between items-center">
                            <div>
                                <p class="text-sm text-[#4A4A4A]">Current Bid</p>
                                <p class="text-lg font-bold text-[#1A1A1A]">
                                    @item.Price.ToString("C")
                                </p>
                            </div>

                            <a asp-action="Details"
                               asp-route-id="@item.ListingId"
                               class="px-4 py-2 bg-[#1A1A1A] text-white rounded-md hover:bg-black transition">
                                View
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        <div class="flex justify-center gap-4 mt-10">

            @if (pageNum > 1)
            {
                <a class="px-5 py-2 bg-[#1A1A1A] text-white rounded-md hover:bg-black transition"
                   href="@Url.Action("Index", new {
                       category = currentCategory,
                       search = currentSearch,
                       sortby = currentSort,
                       page = pageNum - 1
                   })">
                    Previous
                </a>
            }

            @if (pageNum < ViewBag.TotalPages)
            {
                <a class="px-5 py-2 bg-[#1A1A1A] text-white rounded-md hover:bg-black transition"
                   href="@Url.Action("Index", new {
                       category = currentCategory,
                       search = currentSearch,
                       sortby = currentSort,
                       page = pageNum + 1
                   })">
                    Next
                </a>
            }

        </div>
    </div>
</div>