@model Student

<div class="max-w-xl mx-auto mt-10 space-y-8">

    <!-- Page Title -->
    <h1 class="text-3xl font-semibold text-gray-800 border-b pb-2">
        Change Enrollment for @Model.Name
    </h1>

    <!-- Enrollment Form -->
    <form asp-action="ModifyStudentEnrolledCourses" method="post"
          class="bg-white p-6 rounded-lg shadow border border-gray-200 space-y-6">

        <!-- Course Checkboxes -->
        <div class="space-y-3">
            <p class="text-sm font-medium text-gray-700">Select Courses</p>

            @foreach (var course in ViewBag.Courses)
            {
                var isChecked = Model.Courses.Any(c => c.CourseId == course.CourseId);

                <label class="flex items-center gap-3 text-gray-700">
                    <input type="checkbox"
                           id="@course.CourseId"
                           name="enrolledCourses"
                           value="@course.CourseId"
                    @(isChecked ? "checked" : "")
                           class="h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" />
                    <span>@course.Title</span>
                </label>
            }
        </div>
        <input type="hidden" name="studentId" value="@Model.StudentId" />

        <!-- Submit Button -->
        <button type="submit"
                class="w-full bg-blue-600 text-white py-2 rounded-md font-medium
            hover:bg-blue-700 transition">
            Save Changes
        </button>

    </form>

</div>