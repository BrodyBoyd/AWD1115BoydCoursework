@model Student

<div class="max-w-lg mx-auto mt-16 space-y-8">

    <!-- Title -->
    <h1 class="text-3xl font-semibold text-gray-800 border-b pb-2">
        Delete Student
    </h1>

    <!-- Warning Card -->
    <div class="bg-white p-6 rounded-lg shadow border border-gray-200 space-y-4">

        <p class="text-gray-700 text-lg">
            Are you sure you want to delete
            <span class="font-semibold text-gray-900">@Model.Name</span>?
        </p>

        <p class="text-sm text-gray-600">
            This action cannot be undone.
        </p>

        <!-- Form -->
        <form asp-action="DeleteStudent" method="post" class="space-y-4">
            <input type="hidden" name="studentId" asp-for="@Model.StudentId" />

            <button type="submit"
                    class="w-full bg-red-600 text-white py-2 rounded-md font-medium
                hover:bg-red-700 transition">
                Delete Student
            </button>

            <a asp-action="Index"
                   class="block text-center w-full py-2 rounded-md border border-gray-300
                text-gray-700 hover:bg-gray-100 transition">
                Cancel
            </a>
        </form>

    </div>

</div>