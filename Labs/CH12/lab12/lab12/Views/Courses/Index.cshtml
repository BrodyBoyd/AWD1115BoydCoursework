@model IEnumerable<lab12.Models.Course>

@{
    ViewData["Title"] = "Courses";
}

<div class="max-w-4xl mx-auto mt-10 space-y-8">

    <!-- Page Header -->
    <div class="flex items-center justify-between border-b pb-2">
        <h1 class="text-3xl font-semibold text-gray-800">
            Courses
        </h1>

        <a asp-action="Create"
           class="bg-blue-600 text-white px-4 py-2 rounded-md font-medium
                  hover:bg-blue-700 transition">
            Create New
        </a>
    </div>

    <!-- Courses Table -->
    <div class="overflow-hidden rounded-lg shadow border border-gray-200 bg-white">
        <table class="min-w-full text-left">
            <thead class="bg-gray-100 border-b">
                <tr>
                    <th class="px-6 py-3 text-sm font-medium text-gray-700">
                        Title
                    </th>
                    <th class="px-6 py-3 text-sm font-medium text-gray-700 text-right">
                        Actions
                    </th>
                </tr>
            </thead>

            <tbody class="divide-y divide-gray-200">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-gray-50">
                        <td class="px-6 py-4 text-gray-800">
                            @item.Title
                        </td>

                        <td class="px-6 py-4 text-right space-x-3">
                            <a asp-action="Edit" asp-route-id="@item.CourseId"
                               class="text-blue-600 hover:text-blue-800 font-medium">
                                Edit
                            </a>

                            <a asp-action="Details" asp-route-id="@item.CourseId"
                               class="text-gray-700 hover:text-gray-900 font-medium">
                                Details
                            </a>

                            <a asp-action="Delete" asp-route-id="@item.CourseId"
                               class="text-red-600 hover:text-red-800 font-medium">
                                Delete
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>
</div>