@model lab12.Models.Course

@{
    ViewData["Title"] = "Delete Course";
}

<div class="max-w-lg mx-auto mt-16 space-y-8">

    <!-- Page Header -->
    <h1 class="text-3xl font-semibold text-gray-800 border-b pb-2">
        Delete Course
    </h1>

    <!-- Warning Card -->
    <div class="bg-white p-6 rounded-lg shadow border border-gray-200 space-y-4">

        <h3 class="text-xl font-medium text-gray-800">
            Are you sure you want to delete this course?
        </h3>

        <div class="space-y-2">
            <p class="text-sm font-medium text-gray-600">Title</p>
            <p class="text-gray-800 text-lg">@Model.Title</p>
        </div>

        <p class="text-sm text-gray-600">
            This action cannot be undone.
        </p>

        <!-- Delete Form -->
        <form asp-action="Delete" method="post" class="space-y-4">
            <input type="hidden" asp-for="CourseId" />

            <button type="submit"
                    class="w-full bg-red-600 text-white py-2 rounded-md font-medium
                hover:bg-red-700 transition">
                Delete Course
            </button>

            <a asp-action="Index"
                   class="block text-center w-full py-2 rounded-md border border-gray-300
                text-gray-700 hover:bg-gray-100 transition">
                Cancel
            </a>
        </form>

    </div>

</div>
</div>