@model lab12.Models.Course

@{
    ViewData["Title"] = "Create Course";
}

<div class="max-w-xl mx-auto mt-10 space-y-8">

    <!-- Page Header -->
    <h1 class="text-3xl font-semibold text-gray-800 border-b pb-2">
        Create Course
    </h1>

    <!-- Create Form -->
    <form asp-action="Create"
          class="bg-white p-6 rounded-lg shadow border border-gray-200 space-y-6">

        <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm"></div>

        <!-- Title Field -->
        <div class="flex flex-col gap-2">
            <label asp-for="Title" class="text-sm font-medium text-gray-700"></label>

            <input asp-for="Title"
                   class="border border-gray-300 rounded-md px-3 py-2 text-gray-700
            focus:ring-2 focus:ring-blue-500 focus:border-blue-500" />

            <span asp-validation-for="Title" class="text-red-600 text-sm"></span>
        </div>

        <!-- Create Button -->
        <button type="submit"
                class="w-full bg-blue-600 text-white py-2 rounded-md font-medium
            hover:bg-blue-700 transition">
            Create
        </button>
    </form>

    <!-- Back Link -->
    <div>
        <a asp-action="Index"
               class="text-gray-700 hover:text-blue-600 font-medium transition">
            ← Back to List
        </a>
    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}