@model IEnumerable<Destination>

<h1 class="text-4xl font-black text-lime-400 mb-6 tracking-tight
    shadow-[4px_4px_0px_0px_#000] inline-block px-4 py-2 bg-neutral-900
    rotate-[-0.8deg]">
    Manage Destinations
</h1>

<div class="mb-6">
    <a class="inline-block px-5 py-3 bg-lime-600 text-black font-bold uppercase tracking-wide
        shadow-[4px_4px_0px_0px_#000] border-2 border-black
        hover:translate-x-[2px] hover:translate-y-[2px]
        hover:shadow-[2px_2px_0px_0px_#000] transition-all cursor-pointer" asp-action="AddDestination">
        Add Destination
    </a>
</div>
@if (TempData["Message"] != null)
{
    <div class="bg-red-600 text-black font-bold font-mono px-4 py-3
        border-4 border-black shadow-[4px_4px_0px_0px_#000]
        inline-block rotate-[-1deg]">
        <p class="font-medium">@TempData["Message"]</p>
    </div>
}
<div class="overflow-x-auto rotate-[0.4deg]">
    <table class="min-w-full border-separate border-spacing-y-2">
        <thead>
            <tr class="bg-black text-lime-300 uppercase tracking-widest text-sm">
                <td class="px-6 py-4 font-bold border-b-4 border-lime-300">Name</td>
                <td class="px-6 py-4 font-bold border-b-4 border-lime-300 w-32">Actions</td>
            </tr>
        </thead>

        <tbody>
            @foreach (var destination in Model)
            {
                <tr class="bg-neutral-900 text-lime-200 shadow-[4px_4px_0px_0px_#000]
                    hover:bg-neutral-800 transition-all">
                    <td class="px-6 py-5 font-mono border-l-4 border-lime-400">
                        @destination.DestinationName
                    </td>

                    <td class="px-6 py-5 font-mono">
                        <a asp-action="DeleteDestination" asp-route-id="@destination.DestinationId" class="px-3 py-1 bg-red-500 text-black font-bold uppercase text-xs
                            shadow-[2px_2px_0px_0px_#000] border-2 border-black
                            hover:translate-x-[1px] hover:translate-y-[1px]
                            hover:shadow-[1px_1px_0px_0px_#000] transition-all cursor-pointer">
                            Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>