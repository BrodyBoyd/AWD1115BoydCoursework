@model Trip

<div class="min-h-screen flex items-center justify-center">
    <div class="max-w-xl w-full bg-neutral-900 p-10 shadow-[6px_6px_0px_0px_#000]
                border-4 border-red-500 rotate-[0.8deg] space-y-8">

        <!-- Header -->
        <h1 class="text-3xl font-black text-red-400 tracking-tight
                   shadow-[4px_4px_0px_0px_#000] inline-block px-4 py-2 bg-neutral-900
                   rotate-[-1deg]">
            Confirm Delete
        </h1>

        <!-- Message -->
        <p class="text-lime-300 font-mono text-lg">
            Are you absolutely sure you want to delete your trip?
        </p>

        <!-- Optional: Display the name/value -->
        <div class="bg-black text-lime-200 font-mono p-4 border-4 border-lime-400
                    shadow-[3px_3px_0px_0px_#000]">
            <!-- Replace this with whatever property you want to show -->
            @* Example: @Model.Name *@
            <span class="opacity-80">Trip: </span>
            <span class="font-bold"> @ViewBag.DestinationName</span>
        </div>

        <!-- Buttons -->
        <form asp-action="ConfirmDeleteTrip" method="post" class="pt-4 space-x-4">
            @* <input type="hidden" asp-route-id="@Model.TripId" /> *@
            <input type="hidden" name="id" value="@Model.TripId" />

            <button class="px-6 py-3 bg-red-500 text-black font-bold uppercase tracking-wide
                           shadow-[4px_4px_0px_0px_#000] border-2 border-black
                           hover:translate-x-[2px] hover:translate-y-[2px]
                           hover:shadow-[2px_2px_0px_0px_#000] transition-all cursor-pointer">
                Delete
            </button>

            <a asp-action="Index"
               class="px-6 py-3 bg-neutral-800 text-lime-300 font-bold uppercase tracking-wide
                      shadow-[4px_4px_0px_0px_#000] border-2 border-black
                      hover:translate-x-[2px] hover:translate-y-[2px]
                      hover:shadow-[2px_2px_0px_0px_#000] transition-all cursor-pointer">
                Cancel
            </a>
        </form>

    </div>
</div>