@model IEnumerable<Trip>

<div class="mb-6">
    <a asp-action="AddTrip" class="inline-block px-5 py-2 bg-lime-600 text-black font-bold shadow-[4px_4px_0px_0px_#000]
        hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[2px_2px_0px_0px_#000]
        transition-all cursor-pointer">
        Add Trip
    </a>
</div>

<div class="overflow-x-auto rotate-[0.5deg]">
    <table class="min-w-full border-separate border-spacing-y-2">
        <thead>
            <tr class="bg-black text-lime-300 uppercase tracking-widest text-sm">
                <td class="px-6 py-4 font-bold border-b-4 border-lime-300">Destination</td>
                <td class="px-6 py-4 font-bold border-b-4 border-lime-300">Start</td>
                <td class="px-6 py-4 font-bold border-b-4 border-lime-300">End</td>
                <td class="px-6 py-4 font-bold border-b-4 border-lime-300">Stay</td>
                <td class="px-6 py-4 font-bold border-b-4 border-lime-300">Activities</td>
                <td class="px-6 py-4 font-bold border-b-4 border-lime-300"></td>
            </tr>
        </thead>

        <tbody>
            @foreach (var trip in Model)
            {
                <tr class="bg-neutral-900 text-lime-200 shadow-[4px_4px_0px_0px_#000]
                    hover:bg-neutral-800 transition-all">
                    <td class="px-6 py-5 font-mono border-l-4 border-lime-400">
                        @trip.Destination.DestinationName
                    </td>

                    <td class="px-6 py-5 font-mono">
                        @trip.StartDate
                    </td>

                    <td class="px-6 py-5 font-mono">
                        @trip.EndDate
                    </td>

                    <td class="px-6 py-5 font-mono">
                        @trip.Accommodation.Name
                    </td>

                    <td class="px-6 py-5 font-mono">
                        <div class="space-y-1">
                            @foreach (var activity in trip.Activities)
                            {
                                <p class="bg-lime-700 text-black px-2 py-1 inline-block shadow-[2px_2px_0px_0px_#000]">
                                    @activity.Name
                                </p>
                            }
                        </div>
                    </td>
                    <td>
                        <a asp-action="DeleteTrip" asp-route-id="@trip.TripId" class="inline-block px-5 py-2 bg-lime-600 text-black font-bold shadow-[4px_4px_0px_0px_#000]
                            hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[2px_2px_0px_0px_#000]
                            transition-all cursor-pointer">
                            Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>