@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="fin-page">

    <div class="fin-header">
        <span class="fin-eyebrow">Secure Access</span>
        <h1 class="fin-title">Welcome <span>Back</span></h1>
        <div class="fin-divider"></div>
    </div>

    <div class="fin-login-wrap">

        <!-- Local Login -->
        <div class="fin-login-panel">

            <div class="fin-eyebrow" style="margin-bottom: 1.25rem;">Sign in with email</div>

            <div asp-validation-summary="ModelOnly" class="fin-validation-summary"></div>

            <form id="account" method="post" class="fin-login-form">

                <div class="fin-form-field">
                    <label asp-for="Input.Email" class="fin-form-label">Email Address</label>
                    <input asp-for="Input.Email"
                           class="fin-login-input"
                           autocomplete="username"
                           aria-required="true"
                           placeholder="name@example.com" />
                    <span asp-validation-for="Input.Email" class="fin-field-error"></span>
                </div>

                <div class="fin-form-field">
                    <label asp-for="Input.Password" class="fin-form-label">Password</label>
                    <input asp-for="Input.Password"
                           class="fin-login-input"
                           autocomplete="current-password"
                           aria-required="true"
                           placeholder="••••••••" />
                    <span asp-validation-for="Input.Password" class="fin-field-error"></span>
                </div>

                <div class="fin-remember-row">
                    <label class="fin-remember-label">
                        <input asp-for="Input.RememberMe" class="fin-checkbox" />
                        <span>@Html.DisplayNameFor(m => m.Input.RememberMe)</span>
                    </label>
                    <a id="forgot-password" asp-page="./ForgotPassword" class="fin-link">
                        Forgot password?
                    </a>
                </div>

                <button id="login-submit" type="submit" class="fin-login-btn">
                    Sign In →
                </button>

                <div class="fin-login-links">
                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="fin-link">
                        Create an account
                    </a>
                    <span class="fin-link-sep">·</span>
                    <a id="resend-confirmation" asp-page="./ResendEmailConfirmation" class="fin-link">
                        Resend confirmation
                    </a>
                </div>

            </form>
        </div>

        <!-- External Logins -->
        @if ((Model.ExternalLogins?.Count ?? 0) > 0)
        {
            <div class="fin-external-panel">
                <div class="fin-eyebrow" style="margin-bottom: 1.25rem;">Or continue with</div>
                <form id="external-account"
                      asp-page="./ExternalLogin"
                      asp-route-returnUrl="@Model.ReturnUrl"
                      method="post"
                      class="fin-external-form">
                    @foreach (var provider in Model.ExternalLogins!)
                    {
                        <button type="submit"
                                class="fin-external-btn"
                                name="provider"
                                value="@provider.Name"
                                title="Log in using your @provider.DisplayName account">
                            @provider.DisplayName
                        </button>
                    }
                </form>
            </div>
        }

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}