@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>@ViewBag.Title</title>
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
</head>
<body style="margin:0; background-color: #0a0e1a;">

<nav class="fin-nav">
    <div class="fin-nav-inner">

        <!-- Left: Logo + Links -->
        <div class="fin-nav-left">
            <a href="/" class="fin-logo">
                Fin<span>Sim</span>
            </a>

            <div class="fin-nav-links">
                <a asp-controller="Home" asp-action="PlaceInvestment" class="fin-nav-link">
                    Place Investment
                </a>
                <a asp-controller="Home" asp-action="Investments" class="fin-nav-link">
                    Portfolio
                </a>
                <a asp-controller="Home" asp-action="ProfilePage" class="fin-nav-link">
                    Profile Page
                </a>
            </div>
        </div>

        <!-- Right: Balance + Auth -->
        <div class="fin-nav-right">
            @if (User.Identity.IsAuthenticated)
            {
                var balance = ViewBag.Balance as decimal? ?? 0;

                <div class="fin-balance">
                    <span class="fin-balance-label">Balance</span>
                    <span class="fin-balance-value">@balance.ToString("C")</span>
                </div>

                <a asp-action="Deposit" class="fin-nav-deposit">
                    + Deposit
                </a>
            }

            <div class="fin-nav-auth">
                <partial name="_LoginPartial" />
            </div>
        </div>

    </div>
</nav>

<div>
    @RenderBody()
</div>

@RenderSection("Scripts", required: false)

</body>
</html>
