@using Microsoft.AspNetCore.Identity
@using FinancialDashboard.Models

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<div class="flex items-center space-x-6">

    @if (SignInManager.IsSignedIn(User))
    {
        var appUser = await UserManager.GetUserAsync(User);

        @* <!-- Greeting -->
        <a asp-area="Identity"
               asp-page="/Account/Manage/Index"
               class="text-gray-300 hover:text-white transition font-medium">
            Hello, @appUser.UserName
        </a> *@

        <!-- Logout Button -->
        <form asp-area="Identity"
              asp-page="/Account/Logout"
              asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })"
              method="post">

            <button type="submit"
                    class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg font-medium transition">
                Logout
            </button>
        </form>
    }
    else
    {
        <!-- Register -->
        <a asp-area="Identity"
               asp-page="/Account/Register"
               class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-medium transition">
            Register
        </a>

        <!-- Login -->
        <a asp-area="Identity"
               asp-page="/Account/Login"
               class="px-4 py-2 bg-gray-700 hover:bg-gray-800 text-white rounded-lg font-medium transition">
            Login
        </a>
    }
</div>