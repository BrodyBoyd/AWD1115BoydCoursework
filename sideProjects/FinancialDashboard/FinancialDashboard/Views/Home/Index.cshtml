@model HomeViewModel

<div class="fin-page">

    <div class="fin-header">
        <span class="fin-eyebrow">Portfolio Analysis</span>
        <h1 class="fin-title">Your Investment <span>Options</span></h1>
        <div class="fin-divider"></div>
    </div>

    <div class="fin-grid">

        @foreach (var method in Model.EarningMethods)
        {
            <div class="fin-card">

                <div class="fin-card-ticker">instrument</div>
                <h2 class="fin-card-name">@method.Name</h2>

                <div class="fin-separator"></div>

                <div class="fin-metrics">
                    <div class="fin-metric">
                        <span class="fin-metric-label">Expected Return</span>
                        <span class="fin-metric-value return">+@(method.PercentageReturn * 100)%</span>
                    </div>
                    <div class="fin-metric">
                        <span class="fin-metric-label">Chance of Profit</span>
                        <span class="fin-metric-value profit">@(method.ChanceOfProfit)%</span>
                    </div>
                    <div class="fin-metric">
                        <span class="fin-metric-label">Volatility Index</span>
                        <span class="fin-metric-value volatility">@method.Volatility / 7</span>
                    </div>
                </div>

                <div class="fin-vol-bar-wrap">
                    <div class="fin-vol-bar-label">Risk Level</div>
                    <div class="fin-vol-track">
                        <div class="fin-vol-fill" style="width: calc(@method.Volatility / 7 * 100%)"></div>
                    </div>
                </div>

            </div>
        }

    </div>

</div>