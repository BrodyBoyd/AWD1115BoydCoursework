@model PlaceInvestmentViewModel

<div class="min-h-screen bg-gray-900 text-white px-6 py-12">

    <h1 class="text-4xl font-extrabold tracking-tight mb-10 text-center">
        Place an Investment
    </h1>

    <form asp-action="PlaceInvestment" method="post" class="max-w-5xl mx-auto space-y-12">

        <!-- Amount Input -->
        <div class="bg-gray-800/40 border border-gray-700 rounded-2xl p-8 backdrop-blur-sm shadow-xl">
            <label class="block text-xl font-semibold mb-4">Amount to Invest</label>

            <input type="number"
                   name="Amount"
                   step="0.01"
                   min="0"
                   class="w-full px-4 py-3 rounded-lg bg-gray-900 border border-gray-700 text-white
            focus:ring-2 focus:ring-blue-500"
                   placeholder="Enter amount (e.g., 500)" />
        </div>

        <!-- Investment Type Selection -->
        <div>
            <h2 class="text-2xl font-semibold mb-6 text-center">Choose an Investment Type</h2>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">

                @foreach (var method in Model.EarningMethods)
                {
                    <label class="cursor-pointer">
                        <input type="radio"
                               name="SelectedMethod"
                               value="@method.Name"
                               class="peer hidden" />

                        <div class="bg-gray-800/40 border border-gray-700 rounded-2xl p-6 shadow-lg
                            peer-checked:border-blue-500 peer-checked:shadow-blue-500/30
                            hover:shadow-2xl hover:scale-[1.02] transition-all duration-300
                            backdrop-blur-sm">

                            <h3 class="text-2xl font-semibold mb-3">
                                @method.Name
                            </h3>

                            <p class="text-gray-300 mb-4">
                                Expected Return:
                                <span class="text-green-400 font-semibold">
                                    @(method.PercentageReturn * 100)%
                                </span>
                            </p>

                            <p class="text-gray-300">
                                Volatility:
                                <span class="text-yellow-400 font-semibold">
                                    @method.Volatility / 7
                                </span>
                            </p>
                        </div>
                    </label>
                }
            </div>
        </div>

        <!-- Submit Button -->
        <div class="text-center">
            <button type="submit"
                    class="px-10 py-3 bg-blue-600 hover:bg-blue-700 rounded-lg text-lg font-semibold transition">
                Continue
            </button>
        </div>

    </form>

</div>