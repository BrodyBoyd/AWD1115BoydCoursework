@model DepositViewModel

<div class="fin-page">

    <div class="fin-header">
        <span class="fin-eyebrow">Account Management</span>
        <h1 class="fin-title">Deposit <span>Funds</span></h1>
        <div class="fin-divider"></div>
    </div>

    <div class="fin-deposit-wrap">

        <p class="fin-deposit-hint">
            Add capital to your account balance for use in future simulations and investments.
        </p>

        <form asp-action="Deposit" method="post" class="fin-deposit-form">

            <div class="fin-form-field">
                <label class="fin-form-label">Amount to Deposit</label>
                <div class="fin-amount-input-wrap">
                    <span class="fin-currency-symbol">$</span>
                    <input type="number"
                           name="Amount"
                           step="0.01"
                           min="0"
                           class="fin-amount-input fin-deposit-input"
                           placeholder="0.00" />
                </div>
            </div>

            <button type="submit" class="fin-deposit-btn">
                Confirm Deposit →
            </button>

        </form>

    </div>

</div>
