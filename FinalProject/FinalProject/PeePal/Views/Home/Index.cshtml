@using PeePal.Models.ViewModels
@model ReviewsViewModel

<!-- ========================================== -->
<!-- HERO SECTION                               -->
<!-- ========================================== -->
<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-20 pb-16">
    <!-- Background blobs -->
    <div class="absolute top-10 -left-20 w-96 h-96 rounded-full bg-primary/20 blur-3xl animate-pulse-glow" aria-hidden="true"></div>
    <div class="absolute bottom-10 -right-20 w-80 h-80 rounded-full bg-secondary/30 blur-3xl animate-pulse-glow" style="animation-delay:2s" aria-hidden="true"></div>
    <div class="absolute top-1/3 right-1/4 w-64 h-64 rounded-full bg-accent/15 blur-3xl" aria-hidden="true"></div>

    <!-- Dot grid pattern -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image:radial-gradient(circle,#1e293b 1px,transparent 1px);background-size:32px 32px" aria-hidden="true"></div>

    <!-- Hero content -->
    <div class="relative z-10 max-w-6xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

        <!-- Left: Text -->
        <div class="text-left">
            <!-- Badge -->
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary/10 border border-primary/20 mb-8">
                <span class="relative flex h-2.5 w-2.5">
                    <span class="animate-ping-custom absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-primary"></span>
                </span>
                <span class="text-sm font-medium text-primary">Now with AI-powered search</span>
            </div>

            <h1 class="font-display text-5xl sm:text-6xl lg:text-7xl font-bold leading-tight tracking-tight text-foreground" style="text-wrap:balance">
                When You Gotta
                <span class="relative inline-block">
                    <span class="relative z-10 text-primary">Go</span>
                    <span class="absolute -bottom-1 left-0 right-0 h-3 bg-primary/15 rounded-sm" aria-hidden="true"></span>
                </span>
                You Gotta
                <span class="relative inline-block">
                    <span class="relative z-10 text-secondary">Know</span>
                    <span class="absolute -bottom-1 left-0 right-0 h-3 bg-secondary/15 rounded-sm" aria-hidden="true"></span>
                </span>
            </h1>

            <p class="mt-6 text-lg sm:text-xl text-muted-foreground max-w-xl leading-relaxed" style="text-wrap:pretty">
                PeePal is the community-powered restroom finder that helps you discover clean, accessible bathrooms wherever you are. Rated by real people, for real emergencies.
            </p>

            <!-- CTAs -->
            <div class="flex flex-col sm:flex-row items-start gap-4 mt-10">
                <a href="#search" class="group inline-flex items-center gap-2.5 px-8 py-4 rounded-full bg-primary text-primary-foreground font-bold text-base hover:opacity-90 transition-all shadow-lg" style="box-shadow:0 10px 25px -5px rgba(13,150,104,0.25)">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="12" cy="12" r="10"></circle>
                        <polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"></polygon>
                    </svg>
                    Bathrooms Near Me
                </a>
                <a asp-area="Admin" asp-controller="Review" asp-action="Create" class="inline-flex items-center gap-2 px-8 py-4 rounded-full border-2 border-border text-foreground font-bold text-base hover:bg-muted transition-all">
                    Rate a Bathroom
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                        <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                </a>
            </div>

            <!-- Stats -->
            <div class="mt-12 flex flex-wrap items-center gap-8">
                <div class="text-center">
                    <p class="font-display text-3xl font-bold text-foreground">50K+</p>
                    <p class="text-sm text-muted-foreground mt-1">Restrooms Rated</p>
                </div>
                <div class="hidden sm:block w-px h-10 bg-border" aria-hidden="true"></div>
                <div class="text-center">
                    <p class="font-display text-3xl font-bold text-foreground">4.8</p>
                    <p class="text-sm text-muted-foreground mt-1">Average Rating</p>
                </div>
                <div class="hidden sm:block w-px h-10 bg-border" aria-hidden="true"></div>
                <div class="text-center">
                    <p class="font-display text-3xl font-bold text-foreground">120+</p>
                    <p class="text-sm text-muted-foreground mt-1">Cities Covered</p>
                </div>
            </div>
        </div>

        <!-- Right: Hero Illustration -->
        <div class="hidden lg:flex items-center justify-center">
