<div id="search-results" class="mt-16"></div>


@if (ViewBag.RecentlyVisited != null && ((IEnumerable<RecentBathroomDTO>)ViewBag.RecentlyVisited).Any())
{
    var recent = ((IEnumerable<RecentBathroomDTO>)ViewBag.RecentlyVisited).Take(3).ToList();

    <div class="py-4">
        <div class="flex items-center gap-2.5 mb-4">
            <div class="w-7 h-7 rounded-full bg-muted border border-border flex items-center justify-center shrink-0">
                <svg class="w-3 h-3 text-muted-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10" />
                    <polyline points="12 6 12 12 16 14" />
                </svg>
            </div>
            <span class="text-[11px] font-medium tracking-widest text-muted-foreground uppercase">Recently viewed</span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-2.5">
            @foreach (var b in recent)
            {
                var query = Uri.EscapeDataString($"{b.Street}, {b.City}, {b.State} {b.ZipCode}");
                var mapsUrl = $"https://maps.google.com/?q={query}";

                <div class="bg-card border border-border rounded-xl overflow-hidden flex flex-col hover:border-border/80 transition-colors duration-150">

                    <div class="h-[3px] bg-muted border-b border-border relative overflow-hidden">
                        <div class="absolute left-0 top-0 h-full w-[40%] bg-muted-foreground opacity-25"></div>
                    </div>

                    <div class="p-3.5 flex flex-col gap-1.5 flex-1">
                        <span class="inline-flex items-center gap-1 text-[10px] font-medium text-muted-foreground bg-muted border border-border rounded-full px-2 py-0.5 w-fit">
                            <svg class="w-2 h-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="23 4 23 10 17 10" />
                                <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10" />
                            </svg>
                            Visited recently
                        </span>
                        <p class="text-[13px] font-medium text-card-foreground leading-snug">@b.Name</p>
                        <div class="flex items-start gap-1.5 text-[11px] text-muted-foreground leading-relaxed">
                            <svg class="w-2.5 h-2.5 shrink-0 mt-0.5 opacity-50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                                <circle cx="12" cy="10" r="3" />
                            </svg>
                            @($"{b.Street}, {b.City}, {b.State} {b.ZipCode}")
                        </div>
                    </div>

                    <div class="px-3.5 py-2 border-t border-border">
                        <a href="@mapsUrl" target="_blank" class="flex items-center gap-1.5 text-[11px] text-muted-foreground hover:text-foreground transition-colors duration-150 no-underline">
                            <svg class="w-2.5 h-2.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polygon points="3 11 22 2 13 21 11 13 3 11" />
                            </svg>
                            Get directions
                        </a>
                    </div>

                </div>
            }
        </div>
    </div>
}


