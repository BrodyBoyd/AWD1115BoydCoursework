<script>
    // Search helper used by the search button and pagination
    async function doSearch(page = 1) {
        const zip = document.getElementById("zipcode").value.trim();
        if (!zip) return;

        const resultsDiv = document.getElementById("search-results");
        resultsDiv.innerHTML = `
            <div class="text-center py-10 text-muted-foreground">
                Searching...
            </div>
        `;

        try {
            const response = await fetch(`/Home/SearchByZip?zip=${encodeURIComponent(zip)}&page=${page}`);

            if (!response.ok) {
                resultsDiv.innerHTML = "<p class='text-red-500'>Server error.</p>";
                return;
            }
            const html = await response.text();
            resultsDiv.innerHTML = html;
        } catch (err) {
            resultsDiv.innerHTML = "<p class='text-red-500'>Network error.</p>";
        }
    }

    // Attach a single click handler for the main search button
    document.getElementById("search-button").addEventListener("click", () => doSearch(1));

    // Attach a single delegated handler for pagination buttons (works even after partial updates)
    document.addEventListener("click", (e) => {
        const btn = e.target.closest('.page-btn');
        if (!btn) return;
        e.preventDefault();
        const page = parseInt(btn.dataset.page, 10) || 1;
        if (page < 1) return;
        doSearch(page);
    });

    // Popular searches
    document.querySelectorAll("#search .popular-searches button").forEach(btn => {
        btn.addEventListener("click", () => {
            const zipMap = {
                stl: "63101",
                chi: "60601",
                nyk: "10001",
                las: "89101"
            };
            const zip = zipMap[btn.id];
            document.getElementById("zipcode").value = zip;
            doSearch(1);
        });
    });

    // MapInfo

    // Initialize HERE platform
    var platform = new H.service.Platform({
        apikey: "X-UsA7HE5BsPx2kLv8UAs3iPHzK54NQP3nlQvmnxunY"
    });

    var maptypes = platform.createDefaultLayers();

    // Create the map ONCE
    var map = new H.Map(
        document.getElementById('mapContainer'),
        maptypes.vector.normal.map,
        {
            zoom: 10,
            center: { lat: 52.51, lng: 13.4 }
        }
    );

    // Enable interactions
    var behavior = new H.mapevents.Behavior(new H.mapevents.MapEvents(map));
    var ui = H.ui.UI.createDefault(map, maptypes);

    // -------------------------
    // USER LOCATION
    // -------------------------
    function getLocation() {
        if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition(showPosition, showError);
        } else {
            alert("Geolocation is not supported by this browser.");
        }
    }

    function showPosition(position) {
        const lat = Number(position.coords.latitude);
        const lng = Number(position.coords.longitude);

        console.log("User location:", lat, lng);

        map.setCenter({ lat: lat, lng: lng });
        map.setZoom(14);

        var userMarker = new H.map.Marker({ lat: lat, lng: lng });
        map.addObject(userMarker);
        addBathrooms();
    }

    function showError(error) {
        console.error("Geolocation error:", error.message);
    }

    // -------------------------
    // REVIEW MARKERS
    // -------------------------
    function addBathrooms() {
        var svgMarkup = `
                <svg width="32" height="32" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="16" cy="16" r="12" fill="#e53935" stroke="#b71c1c" stroke-width="2"/>
                </svg>
            `;

        var bathrooms = @Html.Raw(Json.Serialize(Model.Bathrooms));

        console.log("bathrooms loaded:", bathrooms);

        bathrooms.forEach(b => {
            if (b.latitude != null && b.longitude != null) {
                const reviewLat = Number(b.latitude);
                const reviewLng = Number(b.longitude);
                console.log("Adding review marker:", reviewLat, reviewLng);
                var icon = new H.map.Icon(svgMarkup);
                var marker = new H.map.Marker({ lat: reviewLat, lng: reviewLng });
                map.addObject(marker);
            } else {
                console.warn("Review missing coordinates:", b);
            }
        });
    }

    // Auto-get user location
    getLocation();

</script>
