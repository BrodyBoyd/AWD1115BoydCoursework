<!-- SEARCH SECTION                             -->
<!-- ========================================== -->
<section id="search" class="py-24 px-6">
    <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 items-stretch">

            <!-- Left card - Search form -->
            <div class="lg:col-span-2 rounded-3xl bg-card border border-border p-8 lg:p-10 flex flex-col justify-center shadow-lg">
                <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 border border-primary/20 text-xs font-semibold text-primary mb-6 w-fit">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="11" cy="11" r="8"></circle>
                        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                    </svg>
                    SEARCH
                </span>

                <h2 class="font-display text-3xl sm:text-4xl font-bold text-card-foreground mb-4" style="text-wrap:balance">
                    Search Your <span class="text-primary">Location</span>
                </h2>

                <p class="text-muted-foreground leading-relaxed mb-8">
                    You deserve the best! No more guessing and ending up at a gross public restroom. Use PeePal to find the cleanest bathroom near you.
                </p>

                <div class="space-y-4">
                    <div>
                        <label for="zipcode" class="block text-sm font-semibold text-card-foreground mb-2">Enter Your Zip Code</label>
                        <div class="relative">
                            <svg class="absolute left-4 top-1/2 -translate-y-1/2 text-muted-foreground" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                                <circle cx="12" cy="10" r="3"></circle>
                            </svg>
                            <input id="zipcode" type="text" placeholder="e.g. 10001" class="w-full pl-12 pr-4 py-3.5 rounded-xl border-2 border-border bg-background text-foreground focus:border-primary focus:outline-none transition-colors text-base" style="font-family:'DM Sans',system-ui,sans-serif" />
                        </div>
                    </div>
                    <button id="search-button" type="button" class="w-full flex items-center justify-center gap-2 py-3.5 rounded-xl bg-primary text-primary-foreground font-bold text-base hover:opacity-90 transition-opacity shadow-md" style="box-shadow:0 4px 14px rgba(13,150,104,0.2)">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <circle cx="11" cy="11" r="8"></circle>
                            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                        </svg>
                        Search Nearby
                    </button>
                    <button class="w-full flex items-center justify-center gap-2 py-3.5 rounded-xl bg-primary text-primary-foreground font-bold text-base hover:opacity-90 transition-opacity shadow-md" style="box-shadow:0 4px 14px rgba(13,150,104,0.2)" onclick="getLocation()">Get My Location</button>

                </div>

                <!-- Popular locations -->
                <div class="mt-8 pt-6 border-t border-border">
                    <p class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-3">Popular Searches</p>
                    <div class="popular-searches flex flex-wrap gap-2">
                        <button id="stl" class="px-3 py-1.5 rounded-full bg-muted text-sm font-medium text-muted-foreground border border-border hover:border-primary/30 hover:text-primary cursor-pointer transition-colors">St. Louis</button>
                        <button id="chi" class="px-3 py-1.5 rounded-full bg-muted text-sm font-medium text-muted-foreground border border-border hover:border-primary/30 hover:text-primary cursor-pointer transition-colors">Chicago</button>
                        <button id="nyk" class="px-3 py-1.5 rounded-full bg-muted text-sm font-medium text-muted-foreground border border-border hover:border-primary/30 hover:text-primary cursor-pointer transition-colors">New York</button>
                        <button id="las" class="px-3 py-1.5 rounded-full bg-muted text-sm font-medium text-muted-foreground border border-border hover:border-primary/30 hover:text-primary cursor-pointer transition-colors">Los Angeles</button>
                    </div>
                </div>
            </div>

            <!-- Right - Map visualization -->
            <div class="lg:col-span-3 rounded-3xl overflow-hidden border border-border shadow-lg min-h-[400px] lg:min-h-0 relative bg-muted">
                <div style="width: 100%; height: 100%;" id="mapContainer"></div>
            </div>
