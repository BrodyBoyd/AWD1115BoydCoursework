                <text x="260" y="429" font-family="sans-serif" font-size="12" fill="#e8970a" text-anchor="end">★ 4.7</text>
                <rect x="258" y="433" width="48" height="5" rx="2" fill="#fef3c7" />
                <rect x="258" y="433" width="40" height="5" rx="2" fill="#e8970a" />

                <rect x="24" y="464" width="290" height="40" rx="8" fill="#fdf4ff" stroke="#e9d5ff" stroke-width="1" />
                <rect x="70" y="472" width="130" height="7" rx="3" fill="#94a3b8" />
                <rect x="70" y="485" width="80" height="5" rx="3" fill="#c4b5fd" />
                <text x="260" y="480" font-family="sans-serif" font-size="12" fill="#e8970a" text-anchor="end">★ 4.5</text>

                <!-- Bottom home indicator -->
                <rect x="130" y="540" width="80" height="4" rx="2" fill="#1e293b" opacity="0.3" />
            </svg>
        </div>

    </div>

    <!-- Bottom fade -->
    <div class="absolute bottom-0 left-0 w-full h-32 bg-gradient-to-t from-background to-transparent pointer-events-none" aria-hidden="true"></div>
</section>




