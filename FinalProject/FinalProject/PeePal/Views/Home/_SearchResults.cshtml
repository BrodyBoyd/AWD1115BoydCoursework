@model IEnumerable<Review>

@if (!Model.Any())
{
    <div class="flex flex-col items-center justify-center py-20 bg-card border border-border rounded-2xl text-center gap-2">
        <svg class="w-10 h-10 text-muted-foreground/40 mb-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8" />
            <line x1="21" y1="21" x2="16.65" y2="16.65" />
        </svg>
        <p class="text-base font-semibold text-muted-foreground">No restrooms found for this ZIP code.</p>
        <p class="text-sm text-muted-foreground/60">Try a different ZIP to see results.</p>
    </div>
}
else
{
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        @foreach (var item in Model)
        {
            <article class="group bg-card border border-border rounded-xl overflow-hidden hover:border-border/80 hover:shadow-md transition-all duration-200 flex flex-col">

                <!-- Top accent line -->
                <div class="h-0.5 w-full bg-gradient-to-r from-primary/50 via-accent/50 to-primary/20"></div>

                <div class="p-5 flex flex-col flex-1">

                    <!-- Name + stars row -->
                    <div class="flex items-start justify-between gap-3 mb-2">
                        <h3 class="text-base font-bold text-card-foreground leading-snug group-hover:text-primary transition-colors">
                            @item.Bathroom?.Name
                        </h3>
                        <!-- Stars -->
                        <div class="flex items-center gap-0.5 flex-shrink-0 mt-0.5">
                            @{
                                var avg = item.AverageScore;
                                for (int i = 1; i <= 5; i++)
                                {
                                    <svg class="h-3.5 w-3.5 @(i <= avg ? "fill-yellow-400" : "fill-muted-foreground/25")" viewBox="0 0 1024 1024">
                                        <path d="M575.85 115.43L661.09 288.05c10.13 20.47 29.68 34.69 52.29 37.96l190.43 27.63c56.99 8.29 79.71 78.28 38.48 118.5L804.35 606.49c-16.37 15.96-23.84 38.99-19.95 61.5l32.54 189.72c9.72 56.79-49.83 100.08-100.79 73.27L545.87 841.45a69.49 69.49 0 0 0-64.67 0l-170.38 89.54c-50.96 26.81-110.51-16.47-100.79-73.27l32.54-189.72c3.89-22.51-3.58-45.54-19.95-61.5L84.78 472.25c-41.24-40.22-18.52-110.21 38.48-118.5l190.43-27.63c22.61-3.27 42.16-17.5 52.29-37.96L451.32 115.43c25.48-51.68 99.05-51.68 124.53 0" />
                                    </svg>
                                }
                            }
                        </div>
                    </div>

                    <!-- Address -->
                    <p class="text-xs text-muted-foreground leading-relaxed flex-1">
                        <svg class="inline w-3 h-3 mr-1 -mt-0.5 opacity-50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                            <circle cx="12" cy="10" r="3" />
                        </svg>
                        @($"{item.Bathroom?.Street}, {item.Bathroom?.City}, {item.Bathroom?.State} {item.Bathroom?.Zip}")
                    </p>

                    <!-- Footer -->
                    <div class="mt-4 pt-4 border-t border-border flex items-center justify-between">
                        <span class="text-xs text-muted-foreground/50 font-mono">@item.AverageScore.ToString("0.0") / 5.0</span>
                        <a asp-area="Admin"
                               asp-controller="Review"
                               asp-action="Details"
                               asp-route-id="@item.ReviewId"
                               asp-route-slug="@item.Bathroom?.Slug"
                               class="inline-flex items-center gap-1 text-xs font-semibold text-primary hover:underline transition">
                            View Details
                            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="5" y1="12" x2="19" y2="12" />
                                <polyline points="12 5 19 12 12 19" />
                            </svg>
                        </a>
                    </div>

                </div>
            </article>
        }
    </div>

    <!-- Pagination -->
    <div class="mt-6 flex items-center justify-center gap-4 text-sm text-muted-foreground">
        <button title="Previous" type="button" data-page="@(ViewBag.CurrentPage - 1)"
                class="page-btn w-8 h-8 inline-flex items-center justify-center rounded-lg border border-border bg-card hover:bg-muted transition disabled:opacity-40">
            <svg viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5">
                <polyline points="15 18 9 12 15 6" />
            </svg>
        </button>

        <span class="font-mono text-xs">Page <span class="text-foreground font-semibold">@ViewBag.CurrentPage</span> of <span class="text-foreground font-semibold">@ViewBag.TotalPages</span></span>

        <button title="Next" type="button" data-page="@(ViewBag.CurrentPage + 1)"
                class="page-btn w-8 h-8 inline-flex items-center justify-center rounded-lg border border-border bg-card hover:bg-muted transition disabled:opacity-40">
            <svg viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5">
                <polyline points="9 18 15 12 9 6" />
            </svg>
        </button>
    </div>
}