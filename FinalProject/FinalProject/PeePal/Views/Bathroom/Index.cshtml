@model Bathroom
@{
    ViewData["Title"] = "Bathroom";
}

<!-- ========================================== -->
<!-- PROFILE PAGE                               -->
<!-- ========================================== -->
<div class="min-h-screen py-16 px-6 relative overflow-hidden mt-16">

    <!-- Background blobs matching site style -->
    <div class="absolute top-10 -left-20 w-96 h-96 rounded-full bg-primary/15 blur-3xl animate-pulse-glow pointer-events-none" aria-hidden="true"></div>
    <div class="absolute bottom-10 -right-20 w-80 h-80 rounded-full bg-secondary/20 blur-3xl animate-pulse-glow pointer-events-none" style="animation-delay:2s" aria-hidden="true"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 h-64 rounded-full bg-accent/10 blur-3xl pointer-events-none" aria-hidden="true"></div>

    <!-- Dot grid -->
    <div class="absolute inset-0 opacity-[0.025] pointer-events-none" style="background-image:radial-gradient(circle,#1e293b 1px,transparent 1px);background-size:32px 32px" aria-hidden="true"></div>

    <div class="relative z-10 max-w-5xl mx-auto">

        <!-- ── PAGE HEADER ── -->
        <div class="mb-10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
                <h1 class="font-display text-4xl sm:text-5xl font-bold text-foreground leading-tight">
                    Bathroom in <span class="text-primary">@Model.City</span>
                </h1>
            </div>
        </div>


        <!-- ── PROFILE INFO CARD ── -->
        <div class="rounded-3xl bg-card border border-border shadow-lg p-8 mb-8">

            <div class="flex items-center gap-3 mb-7">
                <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center text-primary">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                </div>
                <h2 class="font-display text-xl font-bold text-card-foreground">Bathroom Details</h2>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">

                <!-- City -->
                <div class="rounded-2xl bg-muted/50 border border-border px-5 py-4">
                    <p class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-1.5">City</p>
                    <div class="flex items-center gap-2">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary flex-shrink-0"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                        <span class="text-base font-semibold text-card-foreground">@Model.City</span>
                    </div>
                </div>

                <!-- State -->
                <div class="rounded-2xl bg-muted/50 border border-border px-5 py-4">
                    <p class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-1.5">State</p>
                    <div class="flex items-center gap-2">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary flex-shrink-0"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                        <span class="text-base font-semibold text-card-foreground">@Model.State</span>
                    </div>
                </div>

                <!-- Street -->
                <div class="rounded-2xl bg-muted/50 border border-border px-5 py-4">
                    <p class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-1.5">Street</p>
                    <div class="flex items-center gap-2">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary flex-shrink-0"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                        <span class="text-base font-semibold text-card-foreground">@Model.Street</span>
                    </div>
                </div>

                <!-- Zip Code -->
                <div class="rounded-2xl bg-muted/50 border border-border px-5 py-4">
                    <p class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-1.5">Zip Code</p>
                    <div class="flex items-center gap-2">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary flex-shrink-0"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                        <span class="text-base font-semibold text-card-foreground">@Model.Zip</span>
                    </div>
                </div>

            </div>

            <!-- Actions -->
            <div class="mt-8 pt-6 border-t border-border flex flex-col sm:flex-row gap-3">
                <a 
                       class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-full bg-primary text-primary-foreground font-bold text-sm hover:opacity-90 transition-opacity shadow-md"
                       style="box-shadow:0 4px 14px rgba(13,150,104,0.2)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                    Delete Bathroom
                </a>
                @* <a asp-page="./Index"
                       class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-full border-2 border-border text-foreground font-bold text-sm hover:bg-muted transition-all">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                    Edit Profile
                </a> *@
            </div>
        </div>


        <!-- ── FAVORITE BATHROOMS ── -->
        <div class="rounded-3xl bg-card border border-border shadow-lg p-8">

            <div class="flex items-center justify-between gap-3 mb-7">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-accent/10 flex items-center justify-center text-accent">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                    </div>
                    <h2 class="font-display text-xl font-bold text-card-foreground">Favorited By Users:</h2>
                </div>

                @if (Model.FavoritedBy != null && Model.FavoritedBy.Any())
                {
                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-accent/10 border border-accent/20 text-xs font-bold text-accent">
                        @Model.FavoritedBy.Count() saved
                    </span>
                }
            </div>

            @if (Model.FavoritedBy == null || !Model.FavoritedBy.Any())
            {
                <!-- Empty state -->
                <div class="flex flex-col items-center justify-center py-16 text-center">
                    <div class="w-16 h-16 rounded-2xl bg-muted flex items-center justify-center text-muted-foreground mb-4">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                    </div>
                    <p class="font-display text-lg font-bold text-muted-foreground mb-1">No favorites yet</p>
                    <p class="text-sm text-muted-foreground max-w-xs">When you favorite a bathroom, it will show up here for quick access.</p>
                    <a href="/#search" class="mt-6 inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-primary text-primary-foreground font-bold text-sm hover:opacity-90 transition-opacity shadow-md" style="box-shadow:0 4px 14px rgba(13,150,104,0.2)">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                        Find Bathrooms
                    </a>
                </div>
            }
            else
            {
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                    @foreach (var user in Model.FavoritedBy)
                    {
                        <div class="group relative rounded-2xl border border-border bg-background hover:border-accent/40 hover:shadow-md transition-all duration-200 overflow-hidden">

                            <!-- Top color bar -->
                            <div class="h-1.5 w-full bg-gradient-to-r from-accent/60 to-primary/60"></div>

                            <div class="p-5">
                                <!-- Name + remove button -->
                                <div class="flex items-start justify-between gap-2 mb-3">
                                    <h3 class="font-display font-bold text-base text-card-foreground leading-snug group-hover:text-primary transition-colors">
                                        @user.Email
                                    </h3>
                                    <!-- Favorite (filled heart) -->
                                    <button title="Remove from favorites"
                                            class="flex-shrink-0 w-8 h-8 rounded-full bg-accent/10 border border-accent/20 flex items-center justify-center text-accent hover:bg-accent hover:text-white transition-all"
                                            data-bathroom-id="@user.Id">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                                    </button>
                                </div>
                                
                            </div>
                        </div>
                    }
                </div>
            }
            <div class="flex items-center justify-between">
                <a asp-area="" asp-controller="Bathroom" asp-action="EditFavoritedBy" asp-route-Id="@Model.BathroomId"
                       class="inline-flex items-center gap-1 text-xs font-semibold text-primary hover:underline">
                    Edit Favorites
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                </a>
            </div>
        </div>

        <div class="rounded-3xl bg-card border border-border shadow-lg p-8">

            <div class="flex items-center justify-between gap-3 mb-7">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-accent/10 flex items-center justify-center text-accent">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                    </div>
                    <h2 class="font-display text-xl font-bold text-card-foreground">Reviews By Users:</h2>
                </div>

                @if (Model.Reviews != null && Model.Reviews.Any())
                {
                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-accent/10 border border-accent/20 text-xs font-bold text-accent">
                        @Model.Reviews.Count() saved
                    </span>
                }
            </div>

            @if (Model.Reviews != null && Model.Reviews.Any())
            {
                @foreach (var review in Model.Reviews)
                {
                    <article class="
                        bg-card/70 border border-border rounded-xl p-5
                        shadow-lg hover:shadow-xl hover:-translate-y-0.5
                        transition-all duration-200
                        space-y-3
                        ">
                        <div class="flex items-center justify-between">
                            <div class="text-xs text-muted-foreground">Reviewed By:</div>
                            <div class="text-sm font-medium">@review.User.Email</div>
                        </div>
                        <div class="flex items-center justify-between">
                            <div class="text-xs text-muted-foreground">Submitted</div>
                            <div class="text-sm font-medium">@review.DateSubmitted.ToShortDateString()</div>
                        </div>

                        <div class="grid grid-cols-2 gap-y-2 text-sm">
                            <div class="text-muted-foreground">Smell</div>
                            <div class="font-medium">@review.Smell</div>

                            <div class="text-muted-foreground">Cleanliness</div>
                            <div class="font-medium">@review.Cleanliness</div>

                            <div class="text-muted-foreground">Privacy</div>
                            <div class="font-medium">@review.Privacy</div>

                            <div class="text-muted-foreground">Comfort</div>
                            <div class="font-medium">@review.Comfort</div>

                            <div class="text-muted-foreground">Availability</div>
                            <div class="font-medium">@review.Availability</div>
                        </div>

                        <div class="pt-2 flex gap-2">
                            <a asp-area="Admin" asp-controller="Review" asp-action="Details" asp-route-id="@review.ReviewId"
                                   class="px-3 py-1.5 rounded-full border border-border text-sm hover:bg-muted transition">
                                Details
                            </a>

                            <a asp-area="Admin" asp-controller="Review" asp-action="Edit" asp-route-id="@review.ReviewId"
                                   class="px-3 py-1.5 rounded-full bg-primary text-primary-foreground text-sm hover:opacity-90 transition">
                                Edit
                            </a>
                        </div>
                    </article>
                }
            }
            else
            {
                <div class="text-sm text-muted-foreground">No reviews yet for this bathroom.</div>
            }
        </div>


       

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
