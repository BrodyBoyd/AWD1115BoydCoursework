@model PeePal.Areas.Admin.Models.UserViewModel
@{
    ViewData["Title"] = "User Management";
}

<section class="py-20 mt-16 px-6 bg-muted/50 min-h-screen">
    <div class="max-w-6xl mx-auto">

        <!-- Page Header -->
        <div class="flex items-center justify-between mb-12">
            <h1 class="font-display text-4xl font-bold text-foreground">
                User Management
            </h1>

            <a asp-action="Register" asp-controller="Account" asp-area=""
                   class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-primary text-primary-foreground font-semibold shadow-sm hover:opacity-90 transition">
                + Add User
            </a>
        </div>

        <!-- Users Card -->
        <section class="bg-card border border-border rounded-2xl p-6 shadow-md mb-16">
            <header class="mb-6">
                <h2 class="text-2xl font-bold text-card-foreground">Users</h2>
                <p class="text-sm text-muted-foreground mt-1">
                    Manage user accounts and their assigned roles.
                </p>
            </header>

            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="text-left text-muted-foreground border-b border-border">
                            <th class="py-3 font-medium">Username</th>
                            <th class="py-3 font-medium">Roles</th>
                            <th class="py-3"></th>
                            <th class="py-3"></th>
                            <th class="py-3"></th>
                        </tr>
                    </thead>

                    <tbody class="divide-y divide-border">
                        @if (!Model.Users.Any())
                        {
                            <tr>
                                <td colspan="5" class="py-6 text-center text-muted-foreground">
                                    There are no user accounts.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var user in Model.Users)
                            {
                                <tr class="hover:bg-muted/40 transition">
                                    <td class="py-4 font-medium">@user.UserName</td>

                                    <td class="py-4">
                                        @foreach (var role in user.RoleNames)
                                        {
                                            <span class="inline-block text-xs bg-primary/10 text-primary px-2 py-1 rounded-full mr-1 mb-1">
                                                @role
                                            </span>
                                        }
                                    </td>

                                    <!-- Delete User -->
                                    <td class="py-4">
                                        <form method="post" asp-action="Delete" asp-route-id="@user.Id">
                                            <button type="submit"
                                                    class="px-4 py-2 rounded-full bg-red-600 text-white text-sm font-medium hover:bg-red-700 transition">
                                                Delete
                                            </button>
                                        </form>
                                    </td>

                                    <!-- Add to Admin -->
                                    <td class="py-4">
                                        @if (!user.RoleNames.Contains("Admin"))
                                        {
                                            <form method="post" asp-action="AddToAdmin" asp-route-id="@user.Id">
                                                <button type="submit"
                                                        class="px-4 py-2 rounded-full bg-primary text-primary-foreground text-sm font-medium hover:opacity-90 transition">
                                                    Add to Admin
                                                </button>
                                            </form>
                                        }
                                    </td>

                                    <!-- Remove from Admin -->
                                    <td class="py-4">
                                        <form method="post" asp-action="RemoveFromAdmin" asp-route-id="@user.Id">
                                            <button type="submit"
                                                    class="px-4 py-2 rounded-full border border-border text-sm hover:bg-muted transition">
                                                Remove Admin
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </section>

        <!-- Roles Card -->
        <section class="bg-card border border-border rounded-2xl p-6 shadow-md">
            <header class="mb-6">
                <h2 class="text-2xl font-bold text-card-foreground">Roles</h2>
                <p class="text-sm text-muted-foreground mt-1">
                    Manage system roles and permissions.
                </p>
            </header>

            @if (!Model.Roles.Any())
            {
                <form method="post" asp-action="CreateAdminRole">
                    <button type="submit"
                            class="px-6 py-3 rounded-full bg-primary text-primary-foreground font-semibold shadow-sm hover:opacity-90 transition">
                        Create Admin Role
                    </button>
                </form>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="text-left text-muted-foreground border-b border-border">
                                <th class="py-3 font-medium">Role</th>
                                <th class="py-3"></th>
                            </tr>
                        </thead>

                        <tbody class="divide-y divide-border">
                            @foreach (var role in Model.Roles)
                            {
                                <tr class="hover:bg-muted/40 transition">
                                    <td class="py-4 font-medium">@role.Name</td>

                                    <td class="py-4">
                                        <form method="post" asp-action="DeleteRole" asp-route-id="@role.Id">
                                            <button type="submit"
                                                    class="px-4 py-2 rounded-full bg-red-600 text-white text-sm font-medium hover:bg-red-700 transition">
                                                Delete Role
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>

    </div>
</section>